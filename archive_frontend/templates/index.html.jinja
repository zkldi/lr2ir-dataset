{% extends "_base.html.jinja" %}

{% block title %}LR2IR Archive{% endblock %}

{% block extra_styles %}
.stat-grid { display: flex; gap: 12px; flex-wrap: wrap; margin: 14px 0; }
.stat-box { background: #0a0a20; border: 1px solid #446; padding: 12px 20px; flex: 1; text-align: center; }
.stat-val { font-size: 180%; font-weight: bold; color: #eef; }
.stat-lbl { font-size: 9pt; color: #88a; margin-top: 2px; }
.browse-grid { display: flex; flex-wrap: wrap; margin-bottom: 16px; }
.browse-cell { padding: 12px 16px; width: 25%; box-sizing: border-box; border: 1px solid #ccc; background: #fff; color: #333; }
.browse-cell:hover { background: #eef; }
.browse-cell a { font-size: 14pt; font-weight: bold; color: #44e; text-decoration: none; }
.browse-cell a:hover { color: red; }
.browse-cell span { color: #555; font-size: 10pt; }
{% endblock %}

{% block content %}

<div class="stat-grid">
	<div class="stat-box">
		<div class="stat-val">{{ charts }}</div>
		<div class="stat-lbl">Charts</div>
	</div>
	<div class="stat-box">
		<div class="stat-val">{{ scores }}</div>
		<div class="stat-lbl">Scores</div>
	</div>
	<div class="stat-box">
		<div class="stat-val">{{ players }}</div>
		<div class="stat-lbl">Players</div>
	</div>
	<div class="stat-box">
		<div class="stat-val">{{ ghosts }}</div>
		<div class="stat-lbl">Ghosts</div>
	</div>
	<div class="stat-box">
		<div class="stat-val">{{ bbs }}</div>
		<div class="stat-lbl">BBS Messages</div>
	</div>
</div>

<h1>Browse</h1>
<div class="browse-grid">
	<div class="browse-cell">
		<a href="/charts">&#127925; Charts</a><br />
		<span>Browse all scraped BMS charts with leaderboards. Search by title, artist, genre, or MD5.</span>
	</div>
	<div class="browse-cell">
		<a href="/players">&#128100; Players</a><br />
		<span>Browse player profiles.</span>
	</div>
	<div class="browse-cell">
		<a href="/courses">&#127942; Courses</a><br />
		<span>Browse courses (dan/stage sets) with full leaderboards.</span>
	</div>
	<div class="browse-cell">
		<a href="/tables">&#128218; Difficulty Tables</a><br />
		<span>Browse the LR2IR archive through the lens of tables.</span>
	</div>
	<div class="browse-cell">
		<a href="/bbs">&#128172; BBS</a><br />
		<span>Browse the site-wide 1-line message board archive.</span>
	</div>
</div>
<hr />
<h1>API</h1>
<table>
	<tr style="background: #fff;">
		<td style="padding: 12px 16px; width: 25%;">
			Use <code>/api/charts/{md5}</code> to fetch scores as JSON.
			<br />
			You can use <code>?page=NUMBER</code> to move through pages,
			<br />
			and <code>?input=BM</code> to filter on input type.
			<br />
			Like this: <a href="/api/charts/f8dcdfe070630bbb365323c662561a1a?page=2&input=KB">/api/charts/f8dcdfe070630bbb365323c662561a1a?page=2&input=KB</a>
		</td>
	</tr>
</table>
{% endblock %}
