{% extends "_base.html.jinja" %}

{% block title %}LR2IR Archive{% endblock %}

{% block extra_styles %}
.stat-grid { display: flex; gap: 12px; flex-wrap: wrap; margin: 14px 0; }
.stat-box { background: #0a0a20; border: 1px solid #446; padding: 12px 20px; flex: 1; text-align: center; }
.stat-val { font-size: 180%; font-weight: bold; color: #eef; }
.stat-lbl { font-size: 9pt; color: #88a; margin-top: 2px; }
{% endblock %}

{% block content %}

<div class="stat-grid">
	<div class="stat-box">
		<div class="stat-val">{{ charts }}</div>
		<div class="stat-lbl">Charts</div>
	</div>
	<div class="stat-box">
		<div class="stat-val">{{ scores }}</div>
		<div class="stat-lbl">Scores</div>
	</div>
	<div class="stat-box">
		<div class="stat-val">{{ players }}</div>
		<div class="stat-lbl">Players</div>
	</div>
	<div class="stat-box">
		<div class="stat-val">{{ ghosts }}</div>
		<div class="stat-lbl">Ghosts</div>
	</div>
	<div class="stat-box">
		<div class="stat-val">{{ bbs }}</div>
		<div class="stat-lbl">BBS Messages</div>
	</div>
</div>

<h1>Browse</h1>
<table>
	<tr style="background: #fff;">
		<td style="padding: 12px 16px; width: 25%;">
			<a href="/charts" style="font-size: 14pt; font-weight: bold; color: #44e; text-decoration: none;">
				&#127925; Charts
			</a><br />
			<span style="color: #555; font-size: 10pt;">Browse all scraped BMS charts with leaderboards. Search by title, artist, genre, or MD5.</span>
		</td>
		<td style="padding: 12px 16px; width: 25%;">
			<a href="/players" style="font-size: 14pt; font-weight: bold; color: #44e; text-decoration: none;">
				&#128100; Players
			</a><br />
			<span style="color: #555; font-size: 10pt;">Browse player profiles.</span>
		</td>
		<td style="padding: 12px 16px; width: 25%;">
			<a href="/courses" style="font-size: 14pt; font-weight: bold; color: #44e; text-decoration: none;">
				&#127942; Courses
			</a><br />
			<span style="color: #555; font-size: 10pt;">Browse courses (dan/stage sets) with full leaderboards.</span>
		</td>
		<td style="padding: 12px 16px; width: 25%;">
			<a href="/tables" style="font-size: 14pt; font-weight: bold; color: #44e; text-decoration: none;">
				&#128218; Difficulty Tables
			</a><br />
			<span style="color: #555; font-size: 10pt;">Browse the LR2IR archive through the lens of tables.</span>
		</td>
	</tr>
	<tr style="background: #fff;">
		<td style="padding: 12px 16px; width: 25%;">
			<a href="/bbs" style="font-size: 14pt; font-weight: bold; color: #44e; text-decoration: none;">
				&#128172; BBS
			</a><br />
			<span style="color: #555; font-size: 10pt;">Browse the site-wide 1-line message board archive.</span>
		</td>
	</tr>
</table>
<hr />
<h1>API</h1>
<table>
	<tr style="background: #fff;">
		<td style="padding: 12px 16px; width: 25%;">
			Use <code>/api/charts/{md5}</code> to fetch scores as JSON.
			<br />
			You can use <code>?page=NUMBER</code> to move through pages,
			<br />
			and <code>?input=BM</code> to filter on input type.
			<br />
			Like this: <a href="/api/charts/f8dcdfe070630bbb365323c662561a1a?page=2&input=KB">/api/charts/f8dcdfe070630bbb365323c662561a1a?page=2&input=KB</a>
		</td>
	</tr>
</table>
{% endblock %}
