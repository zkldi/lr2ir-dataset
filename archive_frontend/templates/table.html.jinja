{% extends "_base.html.jinja" %}

{% block title %}{{ table.name }} Table - LR2IR Archive{% endblock %}

{% block content %}
<div style="margin-bottom: 8px;">
	<a href="/tables" style="color: #88a;">&#8592; All Tables</a>
</div>

<div style="text-align: center; padding: 14px 10px 12px; background: #0a0a18; border-bottom: 2px solid #446; margin-bottom: 10px;">
	<div style="color: #88a; font-size: 160%; margin-bottom: 4px;">{{ table.symbol }}</div>
	<div style="color: #eef; font-size: 175%; font-weight: bold;">{{ table.name }}</div>
	<div style="color: #888; font-size: 10pt; margin-top: 4px;">{{ table.chart_count }} charts</div>
</div>

<h3>Levels</h3>
<table>
	<thead>
		<tr>
			<th>Level</th>
			<th style="text-align: right;">Charts</th>
		</tr>
	</thead>
	<tbody>
		{% for lv in levels %}
		<tr>
			<td><a href="/tables/{{ table.id }}/{{ lv.level|urlencode }}">{{ table.symbol }}{{ lv.level }}</a></td>
			<td style="text-align: right;">{{ lv.count }}</td>
		</tr>
		{% endfor %}
		{% if levels.is_empty() %}
		<tr><td colspan="2" style="color: #888; text-align: center; padding: 12px;">No levels found.</td></tr>
		{% endif %}
	</tbody>
</table>
{% endblock %}
