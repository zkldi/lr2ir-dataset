{% if clears.total > 0 %}
<div class="clear-bar">
	<div class="cb-fc"   style="width: {{ clears.fc_count     * 100 / clears.total }}%;"></div>
	<div class="cb-hard" style="width: {{ clears.hard_count   * 100 / clears.total }}%;"></div>
	<div class="cb-norm" style="width: {{ clears.normal_count * 100 / clears.total }}%;"></div>
	<div class="cb-easy" style="width: {{ clears.easy_count   * 100 / clears.total }}%;"></div>
	<div class="cb-fail" style="width: {{ clears.failed_count * 100 / clears.total }}%;"></div>
</div>
{% endif %}
