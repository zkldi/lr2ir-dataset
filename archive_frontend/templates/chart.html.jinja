{% extends "_base.html.jinja" %}

{% block title %}{{ meta.title }} - LR2IR Archive{% endblock %}

{% block extra_styles %}
.meta-box { background: #111; border: 1px solid #446; padding: 12px 16px; margin: 10px 0; }
.meta-box table { width: 100%; margin: 0; }
.meta-box th { background: #224; width: 12%; }
.meta-box td { background: #fff; }
.suspended { background: #200; border: 1px solid #800; color: #f88; padding: 6px 10px; margin: 8px 0; font-size: 10pt; }
{% endblock %}

{% block content %}
{% if meta.suspended %}
<div class="suspended">&#9888; This chart is marked as <strong>suspended</strong> in the LR2IR dataset.</div>
{% endif %}

<div style="text-align: center; padding: 18px 10px 14px; background: #0a0a18; border-bottom: 2px solid #446; margin-bottom: 10px;">
	<div style="color: #88a; font-size: 10pt; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px;">{{ meta.genre }}</div>
	<div style="color: #eef; font-size: 200%; font-weight: bold; letter-spacing: 0.02em; line-height: 130%; margin-bottom: 6px;">{{ meta.title }}</div>
	<div style="color: #aab; font-size: 115%; margin-bottom: 12px;">{{ meta.artist }}</div>
	<a href="/api/charts/{{ meta.md5 }}" style="display: inline-block; font-size: 10pt; background: #223; border: 1px solid #557; border-radius: 4px; padding: 4px 14px; color: #9af; letter-spacing: 0.03em; text-decoration: none;">&#x7b;&#x7d;&nbsp;View on the API</a>
</div>

<div class="meta-box">
	<table>
		<tr>
			<th>BPM</th>
			<td>
				{% if meta.bpm_min == meta.bpm_max %}
					{{ meta.bpm_min }}
				{% else %}
					{{ meta.bpm_min }} – {{ meta.bpm_max }}
				{% endif %}
			</td>
			<th>Level</th>
			<td class="{% if meta.keys.contains("14") %}keys-14{% else if meta.keys.contains("9") %}keys-9{% else %}keys-7{% endif %}">{{ meta.keys }} / {{ meta.level }}</td>
			<th>Judge</th>
			<td>{{ meta.judge_rank }}</td>
			{% if meta.bmsid.is_some() %}
			<th>BMSID</th>
			<td>{{ meta.bmsid.unwrap() }}</td>
			{% endif %}
		</tr>
		<tr>
			<th>MD5</th>
			<td colspan="7" style="font-family: monospace; font-size: 10pt;">{{ meta.md5 }}</td>
		</tr>
		{% if !meta.tags.is_empty() %}
		<tr>
			<th>Tags</th>
			<td colspan="7">
				{% for tag in meta.tags %}
				<span class="tag">{{ tag }}</span>
				{% endfor %}
			</td>
		</tr>
		{% endif %}
		{% if meta.body_url.is_some() %}
		<tr>
			<th>Body</th>
			<td colspan="7"><a href="{{ meta.body_url.as_ref().unwrap() }}" target="_blank">{{ meta.body_url.as_ref().unwrap() }}</a></td>
		</tr>
		{% endif %}
		{% if meta.diff_url.is_some() %}
		<tr>
			<th>Diff</th>
			<td colspan="7"><a href="{{ meta.diff_url.as_ref().unwrap() }}" target="_blank">{{ meta.diff_url.as_ref().unwrap() }}</a></td>
		</tr>
		{% endif %}
		{% if meta.comment.is_some() %}
		<tr>
			<th>Note</th>
			<td colspan="7" style="white-space: pre-wrap;">{{ meta.comment.as_ref().unwrap() }}</td>
		</tr>
		{% endif %}
		{% if !meta.last_updated_at.is_empty() %}
		<tr>
			<th>Updated</th>
			<td colspan="7">{{ meta.last_updated_at }} {% if !meta.last_updated_by.is_empty() %}by {{ meta.last_updated_by }}{% endif %}</td>
		</tr>
		{% endif %}
	</table>
</div>

{% if !table_memberships.is_empty() %}
<h3>Appears in these tables:</h3>
<table>
	<thead>
		<tr>
			<th>Table</th>
			<th>Level</th>
		</tr>
	</thead>
	<tbody>
		{% for t in table_memberships %}
		<tr>
			<td><a href="/tables/{{ t.table_id }}">{{ t.name }}</a></td>
			<td><a href="/tables/{{ t.table_id }}/{{ t.level|urlencode }}">{{ t.symbol }}{{ t.level }}</a></td>
		</tr>
		{% endfor %}
	</tbody>
</table>
{% endif %}

<h3>Play Status</h3>
<table>
	<tr>
		<th style="width: 15%;"></th>
		<th style="width: 17%;">Plays</th>
		<th style="width: 17%;">Players</th>
		<th style="width: 17%;">Clears (total)</th>
		<th style="width: 17%;">Clear Players</th>
		<th style="width: 17%;">Clear Rate</th>
	</tr>
	<tr>
		<td style="color: #888;">total</td>
		<td>{{ meta.play_count }}</td>
		<td>{{ meta.play_people }}</td>
		<td>{{ meta.clear_count }}</td>
		<td>{{ meta.clear_people }}</td>
		<td>{{ meta.clear_pct }}</td>
	</tr>
</table>

<table>
	<tr>
		<th style="width: 20%;">FULLCOMBO</th>
		<th style="width: 20%;">HARD</th>
		<th style="width: 20%;">NORMAL</th>
		<th style="width: 20%;">EASY</th>
		<th style="width: 20%;">FAILED</th>
	</tr>
	<tr>
		<td class="rank-clear-FULLCOMBO">{{ meta.fc_count }}</td>
		<td class="rank-clear-HARD">{{ meta.hard_count }}</td>
		<td class="rank-clear-NORMAL">{{ meta.normal_count }}</td>
		<td class="rank-clear-EASY">{{ meta.easy_count }}</td>
		<td class="rank-clear-FAILED">{{ meta.failed_count }}</td>
	</tr>
</table>

{% if meta.play_people > 0 %}
<div class="cb-legend">
	<span class="cb-fc-l">FC ({{ meta.fc_count }})</span>
	<span class="cb-hard-l">HARD ({{ meta.hard_count }})</span>
	<span class="cb-norm-l">NORMAL ({{ meta.normal_count }})</span>
	<span class="cb-easy-l">EASY ({{ meta.easy_count }})</span>
	<span class="cb-fail-l">FAILED ({{ meta.failed_count }})</span>
</div>
<div class="clear-bar" style="width: 100%;">
	<div class="cb-fc"   style="width: {{ meta.fc_count     * 100 / meta.play_people }}%;"></div>
	<div class="cb-hard" style="width: {{ meta.hard_count   * 100 / meta.play_people }}%;"></div>
	<div class="cb-norm" style="width: {{ meta.normal_count * 100 / meta.play_people }}%;"></div>
	<div class="cb-easy" style="width: {{ meta.easy_count   * 100 / meta.play_people }}%;"></div>
	<div class="cb-fail" style="width: {{ meta.failed_count * 100 / meta.play_people }}%;"></div>
</div>
{% endif %}

<h3>
	Leaderboard
	<span style="font-size: 11pt; color: #88a;">({{ total_rows }} entries)</span>
</h3>

<div style="margin: 6px 0 10px; display: flex; gap: 6px; flex-wrap: wrap; align-items: center;">
	<span style="color: #88a; font-size: 10pt;">Filter:</span>
	<a href="/charts/{{ meta.md5 }}" style="padding: 3px 12px; border: 1px solid #446; font-size: 10pt; text-decoration: none;{% if input_filter.is_empty() %} background: #224; color: #eef;{% else %} color: #aab;{% endif %}">All</a>
	<a href="/charts/{{ meta.md5 }}?input=BM" style="padding: 3px 12px; border: 1px solid #446; font-size: 10pt; text-decoration: none;{% if input_filter == "BM" %} background: #224; color: #eef;{% else %} color: #aab;{% endif %}">BM</a>
	<a href="/charts/{{ meta.md5 }}?input=KB" style="padding: 3px 12px; border: 1px solid #446; font-size: 10pt; text-decoration: none;{% if input_filter == "KB" %} background: #224; color: #eef;{% else %} color: #aab;{% endif %}">KB</a>
</div>

<div class="pagination">
	&lt;&lt; page {{ page }}
	{% if page > 1 %}
	<a href="/charts/{{ meta.md5 }}?page={{ page - 1 }}{{ input_qs }}">&laquo; prev</a>
	{% endif %}
	{% if page < total_pages %}
	<a href="/charts/{{ meta.md5 }}?page={{ page + 1 }}{{ input_qs }}">next &raquo;</a>
	{% endif %}
</div>

<table>
	<thead>
		<tr>
			<th>Rank</th>
			<th>Player</th>
			<th>Dan</th>
			<th>Clear</th>
			<th>Grade</th>
			<th>Score</th>
			<th>Combo</th>
			<th>B+P</th>
			<th>PG</th>
			<th>GR</th>
			<th>GD</th>
			<th>BD</th>
			<th>PR</th>
			<th>OP</th>
			<th>OP</th>
			{% if meta.is_dp %}<th>OP</th><th>OP</th>{% endif %}
			<th>Input</th>
			<th>Client</th>
			<th>Ghost</th>
		</tr>
	</thead>
	<tbody>
		{% for r in rows %}
		<tr{% if r.is_cheated %} class="row-cheated"{% endif %}>
			<td align="center">{{ r.rank }}</td>
			<td>
				<a href="/players/{{ r.player_id }}">{{ r.player_name }}</a>
				{% if r.is_cheated %}<div class="cheated-label">CHEATED</div>{% endif %}
			</td>
			<td>{{ r.dan }}</td>
			<td class="rank-clear-{{ r.clear_class }}">{{ r.clear_type }}</td>
			<td>
				{{ r.letter_rank }}
				{% if !r.grade_delta.is_empty() %}
				<div style="font-size: 9pt; color: #88a; font-family: monospace; margin-top: 2px;">{{ r.grade_delta }}</div>
				{% endif %}
			</td>
			<td style="white-space: pre-wrap;">{{ r.score_display }}</td>
			<td>{{ r.combo_display }}</td>
			<td>{{ r.bad_poor }}</td>
			<td>{{ r.pgreat }}</td>
			<td>{{ r.great }}</td>
			<td>{{ r.good }}</td>
			<td>{{ r.bad }}</td>
			<td>{{ r.poor }}</td>
			<td>{{ r.option_1 }}</td>
			<td>{{ r.option_2 }}</td>
			{% if meta.is_dp %}<td>{{ r.option_3 }}</td><td>{{ r.option_4 }}</td>{% endif %}
			<td>{{ r.input }}</td>
			<td>{{ r.client }}</td>
			<td style="text-align: center; white-space: nowrap;">
				{% if r.has_ghost %}
				<a href="/ghosts/{{ meta.md5 }}/{{ r.player_id }}" style="font-size: 9pt; color: #9cf; text-decoration: none; border: 1px solid #446; padding: 1px 6px; border-radius: 3px;">dl</a>
				{% else %}
				<span style="font-size: 0.5rem;">missing</span>
				{% endif %}
			</td>
		</tr>
		{% if !r.note.is_empty() %}
		<tr class="gray">
			<td></td>
			<td colspan="{% if meta.is_dp %}19{% else %}17{% endif %}" style="white-space: pre-wrap;">{{ r.note }}</td>
		</tr>
		{% endif %}
		{% endfor %}
		{% if rows.is_empty() %}
		<tr><td colspan="{% if meta.is_dp %}18{% else %}16{% endif %}" style="color: #888; text-align: center; padding: 12px;">No scores on this page.</td></tr>
		{% endif %}
	</tbody>
</table>

<div class="pagination">
	{% if page > 1 %}
	<a href="/charts/{{ meta.md5 }}?page={{ page - 1 }}{{ input_qs }}">&laquo; prev</a>
	{% endif %}
	page {{ page }} of {{ total_pages }}
	{% if page < total_pages %}
	<a href="/charts/{{ meta.md5 }}?page={{ page + 1 }}{{ input_qs }}">next &raquo;</a>
	{% endif %}
</div>

{% endblock %}
